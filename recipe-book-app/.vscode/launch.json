{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dev + Debug",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "pattern": "Local:.*http://localhost:([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "action": "debugWithChrome",
                "webRoot": "${workspaceFolder}/src"
            }
        }
    ]
}
